rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User avatars — each user can only read/write their own avatar
    match /avatars/{userId} {
      allow read:  if request.auth != null;
      allow create, update: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size  < 10 * 1024 * 1024  // max 10 MB pre-compression
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                   && request.auth.uid == userId;
    }

    // Member photos — readable by any authenticated user
    match /member_photos/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Branding assets (e.g. logos) must be publicly readable to display on the login screen,
    // and writeable by any authenticated staff/admin.
    match /branding/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Everything else is denied
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
